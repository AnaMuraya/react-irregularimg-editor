{
  "name": "react-irregularimg-editor",
  "version": "0.2.0",
  "description": "A React + TypeScript component for cropping and masking images into irregular shapes — freeform/polygon crop, preset shape masks, rotate/zoom/reposition adjustments, and PNG/SVG export.",
  "type": "commonjs",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./freehand": {
      "import": {
        "types": "./dist/freehand.d.mts",
        "default": "./dist/freehand.mjs"
      },
      "require": {
        "types": "./dist/freehand.d.ts",
        "default": "./dist/freehand.js"
      }
    },
    "./polygon": {
      "import": {
        "types": "./dist/polygon.d.mts",
        "default": "./dist/polygon.mjs"
      },
      "require": {
        "types": "./dist/polygon.d.ts",
        "default": "./dist/polygon.js"
      }
    },
    "./preset": {
      "import": {
        "types": "./dist/preset.d.mts",
        "default": "./dist/preset.mjs"
      },
      "require": {
        "types": "./dist/preset.d.ts",
        "default": "./dist/preset.js"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.mts",
        "default": "./dist/core.mjs"
      },
      "require": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnaMuraya/custom-demo.git"
  },
  "keywords": [
    "react",
    "typescript",
    "image",
    "editor",
    "crop",
    "mask",
    "irregular",
    "polygon",
    "freeform",
    "clip",
    "canvas",
    "components",
    "ui"
  ],
  "author": "A.M",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AnaMuraya/custom-demo/issues"
  },
  "homepage": "https://github.com/AnaMuraya/custom-demo#readme",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.39.4",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.9"
  }
}
